# =============================================
# Variables de entorno - Conciliador Bancario
# Copiá este archivo como .env y completá los valores
# =============================================

# Backend (FastAPI)
# Clave de acceso requerida para todas las rutas protegidas
API_KEY=cambia_esto_por_una_clave_segura

# URL del frontend (para CORS)
FRONTEND_URL=https://conciliador-virid.vercel.app

# Puerto del servidor (default: 8000)
PORT=8000

# Tamaño máximo de archivo en MB (default: 50)
MAX_FILE_SIZE_MB=50

# Frontend (Vite/React)
# URL del backend
VITE_API_URL=https://tu-backend.render.com

# =============================================
# Variables de entorno — Conciliador Bancario
# Copiá este archivo como .env y completá los valores
# =============================================

# --- Autenticación JWT ---
# Clave secreta para firmar tokens (generá una con: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga

# Contraseña del usuario admin por defecto (solo al crear la DB por primera vez)
ADMIN_PASSWORD=cambia_esto_tambien

# Horas de validez del token JWT (default: 8)
TOKEN_EXPIRE_HORAS=8

# Ruta del archivo SQLite de usuarios (default: ./usuarios.db)
AUTH_DB_PATH=./usuarios.db

# --- Servidor ---
PORT=8000
FRONTEND_URL=https://conciliador-virid.vercel.app
MAX_FILE_SIZE_MB=50

# --- Logging ---
# Niveles: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_MB=10
LOG_BACKUPS=5
ENVIRONMENT=production

# --- Frontend (Vite) ---
VITE_API_URL=https://tu-backend.render.com
